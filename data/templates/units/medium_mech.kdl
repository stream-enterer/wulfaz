unit id="medium_mech" {
    tags "mech" "medium"
    attributes {
        attribute name="combat_width" base=2
        attribute name="health" base=8 min=0
        attribute name="max_health" base=8
        attribute name="shields" base=0 min=0
    }
    dice {
        die {
            face "damage" 2
            face "damage" 3
            face "damage" 4
            face "damage" 5
            face "blank"
            face "blank"
        }
    }
}
