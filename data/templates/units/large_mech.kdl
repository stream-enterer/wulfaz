unit id="large_mech" {
    tags "mech" "large" "heavy"
    attributes {
        attribute name="combat_width" base=3
        attribute name="health" base=12 min=0
        attribute name="max_health" base=12
        attribute name="shields" base=0 min=0
    }
    dice {
        die {
            face "damage" 3
            face "damage" 4
            face "damage" 5
            face "damage" 6
            face "blank"
            face "blank"
        }
    }
}
